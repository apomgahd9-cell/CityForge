{
  "schemaVersion": 1,
  "version": 1,
  "description": "Formulas that convert simulation metrics into a growth probability. Referenced by growth_profiles.",
  "models": {
    "residential_standard": {
      "description": "Standard residential growth model.",
      "baseChance": 0.05,
      "modifiers": [
        { "metric": "residential_demand", "weight": 0.002, "contributionRange": [-0.1, 0.2] },
        { "metric": "happiness", "weight": 0.001, "contributionRange": [-0.05, 0.1] },
        { "metric": "land_value", "weight": 0.0008, "contributionRange": [-0.03, 0.08] }
      ],
      "minChance": 0.01,
      "maxChance": 0.25
    },
    "commercial_standard": {
      "description": "Standard commercial growth model.",
      "baseChance": 0.04,
      "modifiers": [
        { "metric": "commercial_demand", "weight": 0.003, "contributionRange": [-0.1, 0.25] },
        { "metric": "customer_access", "weight": 0.002, "contributionRange": [-0.05, 0.15] },
        { "metric": "land_value", "weight": 0.001, "contributionRange": [-0.02, 0.1] }
      ],
      "minChance": 0.01,
      "maxChance": 0.20
    },
    "industrial_standard": {
      "description": "Standard industrial growth model.",
      "baseChance": 0.06,
      "modifiers": [
        { "metric": "industrial_demand", "weight": 0.004, "contributionRange": [-0.1, 0.3] },
        { "metric": "freight_access", "weight": 0.003, "contributionRange": [-0.05, 0.2] },
        { "metric": "pollution", "weight": -0.001, "contributionRange": [-0.05, 0.0] }
      ],
      "minChance": 0.02,
      "maxChance": 0.30
    },
    "standard_decline": {
      "description": "Standard decline model.",
      "baseChance": 0.03,
      "modifiers": [
        { "metric": "happiness", "weight": -0.002, "contributionRange": [-0.1, 0.0] },
        { "metric": "land_value", "weight": -0.001, "contributionRange": [-0.05, 0.0] }
      ],
      "minChance": 0.01,
      "maxChance": 0.15
    }
  }
}
